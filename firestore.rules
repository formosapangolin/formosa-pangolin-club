rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'Armand7951@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 100
        && (!('displayName' in data) || data.displayName is string)
        && (!('membershipLevel' in data) || data.membershipLevel in ['Standard', 'Prestige', 'Founding']);
    }

    function isValidBooking(data) {
      return data.userId == request.auth.uid
        && data.itineraryId is string
        && data.guestCount is number
        && data.guestCount > 0
        && data.guestCount <= 10;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'bio', 'photoURL', 'membershipLevel']);
    }

    // Itineraries (Publicly viewable by members, manageable by admins)
    match /itineraries/{itineraryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Bookings (Members see their own, admins see all)
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidBooking(request.resource.data);
      allow update: if (resource.data.userId == request.auth.uid || isAdmin())
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'guestCount']);
      allow delete: if isAdmin();
    }
    
    // Admins collection (Managed manually or via cloud console)
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
